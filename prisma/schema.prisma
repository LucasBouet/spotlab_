datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
  output   = "./prisma_db"
}

enum Role {
  ADMIN
  USER
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String
  role         Role          @default(USER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     Session[]
  likedTracks  LikedTrack[]
  settings     UserSetting[]
  playlists    Playlist[]
  devices      Device[]
  passkeys     Passkey[]
  playEvents   PlayEvent[]
  recommendations Recommendation[]

  sentFriendRequests     Friendship[] @relation("SentFriendRequests")
  receivedFriendRequests Friendship[] @relation("ReceivedFriendRequests")
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model LikedTrack {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deezerTrackId Int
  title         String
  artistName    String
  artistId      Int?
  albumTitle    String
  albumCover    String
  duration      Int
  createdAt     DateTime @default(now())

  @@unique([userId, deezerTrackId])
}

model Playlist {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  tracks    PlaylistTrack[]
}

model PlaylistTrack {
  id            String   @id @default(cuid())
  playlistId    String
  playlist      Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  deezerTrackId Int
  title         String
  artistName    String
  artistId      Int?
  albumTitle    String
  albumCover    String
  duration      Int
  addedAt       DateTime @default(now())
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model UserSetting {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
}

model Device {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId   String
  name       String
  platform   String
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@unique([userId, deviceId])
}

// A WebAuthn credential (passkey) the user can log in with. Works with platform
// authenticators (Face/Touch ID, Windows Hello) and roaming providers such as
// Bitwarden. `credentialId`/`publicKey` come straight from the authenticator;
// `counter` is bumped on every login to help detect cloned authenticators.
model Passkey {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String   @unique
  publicKey    Bytes
  counter      Int      @default(0)
  transports   String?
  deviceType   String?
  backedUp     Boolean  @default(false)
  name         String
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime @default(now())

  @@index([userId])
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

// A directional friendship row: the requester sent an invite to the addressee.
// PENDING while awaiting a response, ACCEPTED once approved. There is at most
// one row per ordered (requester, addressee) pair; the send flow also rejects a
// new request when a row already exists in the *reverse* direction, so two
// users can never end up with two competing rows.
model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  requester   User             @relation("SentFriendRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String
  addressee   User             @relation("ReceivedFriendRequests", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
}

// One row per *qualified* play: written once a track has been actually played
// for at least the scrobble threshold (~30s) on the primary output device.
// Track metadata is denormalized so stats survive even if the source track
// later disappears from Deezer; genre is kept out (cached separately in
// TrackGenre) because it needs an extra Deezer round-trip to resolve.
model PlayEvent {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deezerTrackId Int
  title         String
  artistName    String
  artistId      Int?
  albumTitle    String
  albumCover    String
  duration      Int
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([userId, deezerTrackId])
}

// Per-track genre cache, resolved lazily from Deezer (track -> album -> genre)
// the first time a track is played. Shared across all users; genreName stays
// null when Deezer has no genre for the album (a resolved "unknown", so we
// don't keep refetching it).
model TrackGenre {
  deezerTrackId Int      @id
  albumId       Int?
  genreId       Int?
  genreName     String?
  // "lastfm" (granular, preferred) or "deezer" (coarse fallback). A "deezer"
  // row is re-resolved to "lastfm" on the next play once a key is configured.
  source        String?
  updatedAt     DateTime @updatedAt
}

// Cached homepage recommendations, one row per (user, time window). The heavy
// build (dozens of Deezer round-trips seeded from the user's play history) runs
// on a cache miss or when `computedAt` is older than the TTL, then the JSON
// result is stored in `payload`. Keeps the homepage instant and Deezer-friendly
// across frequent visits. `window` is "day" | "week" | "all".
model Recommendation {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  window     String
  payload    String
  computedAt DateTime @default(now())

  @@unique([userId, window])
}
