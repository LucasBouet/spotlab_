# Base32 TOTP secret used to authorize requests to /config.
# Generate one with: python -c "import pyotp; print(pyotp.random_base32())"
TOTP_SECRET=

# If set, overwrites [downloads].folder in config.toml on every /config call.
# Leave empty to keep whatever value is already in config.toml.
FOLDER=

# Optional overrides
# HOST=0.0.0.0
# PORT=8081
